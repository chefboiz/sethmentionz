POLYMARKET_API_KEY=

TELEGRAM_BOT_TOKEN=           # https://t.me/BotFather
TELEGRAM_CHAT_ID=             # your personal or group chat ID

DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sethmentionz

ANTHROPIC_API_KEY=sk-ant-...  # https://console.anthropic.com
NEWS_API_KEY=                 # https://newsapi.org (optional — Phase 2 signal leg)

# Polymarket CLOB auth (needed from Phase 5)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Scanning config
RESOLUTION_WINDOW_HOURS=12    # only process markets resolving within this many hours

# Confidence blend weights (Phase 2)
LLM_WEIGHT=0.6
SIGNAL_WEIGHT=0.4

# Edge thresholds (Phase 3)
CONFIDENCE_THRESHOLD=0.75     # lower for testing (default 0.75); raise to 0.94 for production
EDGE_MIN_PCT=0.05
EDGE_MAX_PRICE=0.96
MIN_VIABLE_SIZE_USD=50
LIQUIDITY_THRESHOLD_USD=200   # below this total ask-side depth (USD) triggers THIN flag

# Execution (Phase 5)
SLIPPAGE_TOLERANCE=0.01       # max extra cents above best ask for limit price
FILL_TIMEOUT_MINUTES=10       # cancel unfilled GTC orders after this many minutes
FILL_MONITOR_SECONDS=30       # how often to poll CLOB for fill status
TRADING_PAUSED=false          # set true to disable execution without stopping the process

# Resolution + calibration (Phase 6)
RESOLUTION_CHECK_MINUTES=15   # how often to poll Gamma API for resolved markets

# Scanner poll interval in minutes
SCAN_INTERVAL_MINUTES=30
# Price-refresh interval in seconds (for already-flagged opportunities)
PRICE_REFRESH_SECONDS=90
# How often to check for new unalerted opportunities
ALERT_CHECK_SECONDS=60
# How often to poll Telegram for button presses
CALLBACK_POLL_SECONDS=5
